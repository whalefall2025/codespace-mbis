cmd_save() {
    local remote="origin"
    local branch tracking configured_remote configured_merge configured_branch
    local remote_ref counts
    local behind=0
    local ahead=0
    local remote_branch_exists=0
    local made_commit=0
    local changed_count=0
    local message head_short repo_root agentsview_export_script

    # Must be inside a Git repository.
    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        cat >&2 <<'EOF'
mbis save needs to be run from inside a project folder that uses Git.

Try opening the project folder first, then run:
  mbis save
EOF
        return 1
    fi

    # Refuse to run during an unfinished Git operation.
    local merge_head rebase_merge rebase_apply cherry_pick_head revert_head sequencer bisect_log index_lock
    merge_head="$(git rev-parse --git-path MERGE_HEAD)"
    rebase_merge="$(git rev-parse --git-path rebase-merge)"
    rebase_apply="$(git rev-parse --git-path rebase-apply)"
    cherry_pick_head="$(git rev-parse --git-path CHERRY_PICK_HEAD)"
    revert_head="$(git rev-parse --git-path REVERT_HEAD)"
    sequencer="$(git rev-parse --git-path sequencer)"
    bisect_log="$(git rev-parse --git-path BISECT_LOG)"
    index_lock="$(git rev-parse --git-path index.lock)"

    if [[ -e "$index_lock" ]]; then
        cat >&2 <<'EOF'
mbis save stopped because Git appears to be busy.

Close any other Git commands or Git apps that might be running, then try:
  mbis save
EOF
        return 1
    fi

    if [[ -e "$merge_head" || -d "$rebase_merge" || -d "$rebase_apply" ||
          -e "$cherry_pick_head" || -e "$revert_head" || -d "$sequencer" ||
          -e "$bisect_log" ]]; then
        cat >&2 <<'EOF'
mbis save stopped because another Git operation is already in progress.

Your files were not changed by mbis save.

Finish or cancel the current Git operation first. Useful commands:
  git status
  git rebase --continue
  git rebase --abort
  git merge --abort
EOF
        return 1
    fi

    if [[ -n "$(git diff --name-only --diff-filter=U)" ]]; then
        cat >&2 <<'EOF'
mbis save stopped because some files still have unresolved conflicts.

Open the conflicted files, choose the final version you want to keep, then run:
  git add -A
  mbis save
EOF
        return 1
    fi

    # Must be on a named branch.
    branch="$(git branch --show-current 2>/dev/null || true)"
    if [[ -z "$branch" ]]; then
        cat >&2 <<'EOF'
mbis save stopped because this project is not currently on a branch.

A safe beginner-friendly fix is to create a branch:
  git switch -c my-branch

Then run:
  mbis save
EOF
        return 1
    fi

    # Make sure the remote exists before doing anything that creates a commit.
    if ! git remote get-url "$remote" >/dev/null 2>&1; then
        cat >&2 <<EOF
mbis save could not find a GitHub remote named '$remote'.

Add the GitHub repository first, for example:
  git remote add origin <repo-url>

No commit was created.
EOF
        return 1
    fi

    printf 'Step 1/4: Checking GitHub for updates...\n'

    if ! git fetch "$remote" --prune; then
        cat >&2 <<'EOF'
mbis save could not reach GitHub.

Check your internet connection, GitHub sign-in, and repository access.

No commit was created.
EOF
        return 1
    fi

    # Sync AgentsView state after the basic Git checks and successful fetch.
    # This keeps "could not reach GitHub" from creating extra local changes.
    printf 'Exporting AgentsView database...\n'

    repo_root="$(git rev-parse --show-toplevel)"
    agentsview_export_script="$repo_root/agentsview_export/export_agentsview.sh"

    if [[ ! -x "$agentsview_export_script" ]]; then
        cat >&2 <<EOF
mbis save could not export the AgentsView database.

Expected an executable script here:
  $agentsview_export_script

Make it executable, then try again:
  chmod +x "$agentsview_export_script"
  mbis save

No commit was created.
EOF
        return 1
    fi

    if ! "$agentsview_export_script"; then
        cat >&2 <<EOF
mbis save could not export the AgentsView database.

The GitHub save was stopped so it does not upload an old or missing database export.

Check the export message above, then try:
  mbis save

No commit was created.
EOF
        return 1
    fi

    printf 'Step 2/4: Looking for local file changes...\n'

    changed_count="$(git status --porcelain=v1 --untracked-files=all | wc -l | tr -d '[:space:]')"

    if (( changed_count > 0 )); then
        printf 'Found %d changed file(s). Creating a local save point...\n' "$changed_count"

        if ! git var GIT_AUTHOR_IDENT >/dev/null 2>&1; then
            cat >&2 <<'EOF'
mbis save could not create a save point because Git does not know your name and email yet.

Set them once with:

  git config --global user.name "Your Name"
  git config --global user.email "you@example.com"

Then run:
  mbis save

No commit was created.
EOF
            return 1
        fi

        if ! git add -A; then
            cat >&2 <<'EOF'
mbis save could not prepare your changed files.

Your files were not deleted. Check the Git message above, then try:
  mbis save
EOF
            return 1
        fi

        if git diff --cached --quiet; then
            if [[ -n "$(git status --porcelain=v1 --untracked-files=all)" ]]; then
                cat >&2 <<'EOF'
mbis save found changes, but they are not normal file changes that this command can save.

This can happen with advanced Git features such as submodules.

Current Git status:
EOF
                git status --short >&2
                return 1
            fi

            printf 'No file changes to save.\n'
        else
            message="mbis save $(date -u +"%Y-%m-%d %H:%M UTC")"

            if ! git commit -m "$message"; then
                cat >&2 <<'EOF'
mbis save could not create the local save point.

Common causes:
  - Git user.name or user.email is missing
  - a pre-commit check failed
  - a file could not be added

Check the Git message above. Your files were not deleted.
EOF
                return 1
            fi

            made_commit=1

            if [[ -n "$(git status --porcelain=v1 --untracked-files=all)" ]]; then
                cat >&2 <<'EOF'
mbis save created a local save point, but some file changes are still not saved.

This can happen when a Git hook edits files during commit.

Run this again to save the remaining changes:
  mbis save
EOF
                git status --short >&2
                return 1
            fi
        fi
    else
        printf 'No local file changes to save.\n'
    fi

    # If this repository has no commits yet and there was nothing to commit, stop cleanly.
    if ! git rev-parse --verify HEAD >/dev/null 2>&1; then
        cat <<'EOF'
Nothing to save yet.

Create or add a file, then run:
  mbis save
EOF
        return 0
    fi

    # Use only origin/current-branch for beginner predictability.
    # If the branch tracks something else, stop instead of pushing somewhere surprising.
    tracking="$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"

    if git show-ref --verify --quiet "refs/remotes/$remote/$branch"; then
        remote_ref="$remote/$branch"
        remote_branch_exists=1
    fi

    if [[ -n "$tracking" && "$tracking" != "$remote/$branch" ]]; then
        cat >&2 <<EOF
mbis save stopped because this branch is connected to '$tracking',
but mbis save expects it to save to '$remote/$branch'.

This is unusual for a beginner workflow, so mbis save will not guess where to push.

Ask for help, or inspect it with:
  git status
  git branch -vv
EOF
        return 1
    fi

    configured_remote="$(git config --get "branch.$branch.remote" || true)"
    configured_merge="$(git config --get "branch.$branch.merge" || true)"
    configured_branch="${configured_merge#refs/heads/}"

    if [[ -z "$tracking" &&
          "$configured_remote" == "$remote" &&
          "$configured_branch" == "$branch" &&
          "$remote_branch_exists" -eq 0 ]]; then
        cat >&2 <<EOF
mbis save stopped because this branch used to be connected to '$remote/$branch',
but that branch no longer exists on GitHub.

To avoid accidentally re-creating a branch that someone deleted, mbis save stopped.

Ask for help, or check:
  git status
  git branch -vv
EOF
        return 1
    fi

    printf 'Step 3/4: Making sure your work is based on the latest GitHub version...\n'

    if (( remote_branch_exists == 1 )); then
        if ! counts="$(git rev-list --left-right --count "$remote_ref"...HEAD)"; then
            cat >&2 <<EOF
mbis save could not compare your work with GitHub branch '$remote_ref'.

Check:
  git status
EOF
            return 1
        fi

        read -r behind ahead <<<"$counts"

        if (( behind > 0 )); then
            printf 'GitHub has %d newer commit(s). Updating your work safely...\n' "$behind"

            if ! git rebase "$remote_ref"; then
                local conflict_count
                conflict_count="$(git diff --name-only --diff-filter=U | wc -l | tr -d '[:space:]')"

                cat >&2 <<'EOF'
mbis save stopped because Git needs your help combining changes.

Your local save point still exists on your computer.
Nothing was uploaded to GitHub yet.

What to do next:
  1. Open the conflicted files and choose the final text you want.
  2. Mark them fixed:
       git add -A
  3. Continue the update:
       git rebase --continue
  4. Save again:
       mbis save

To cancel this update and go back:
  git rebase --abort
EOF

                if (( conflict_count > 0 )); then
                    printf '\nFiles needing your choice:\n' >&2
                    git diff --name-only --diff-filter=U >&2
                fi

                return 1
            fi

            if ! counts="$(git rev-list --left-right --count "$remote_ref"...HEAD)"; then
                cat >&2 <<'EOF'
mbis save updated your branch, but could not re-check it afterward.

Check:
  git status
EOF
                return 1
            fi

            read -r behind ahead <<<"$counts"
        else
            printf 'Your branch is already based on the latest GitHub version.\n'
        fi
    else
        printf "This branch is not on GitHub yet. It will be published as '%s'.\n" "$branch"
    fi

    printf 'Step 4/4: Uploading to GitHub...\n'

    if (( remote_branch_exists == 0 )); then
        if ! git push -u "$remote" "HEAD:$branch"; then
            cat >&2 <<EOF
mbis save created a local save point, but could not upload it to GitHub.

Your work is still saved on your computer.

Check the Git message above. Then try:
  git push -u $remote $branch
EOF
            return 1
        fi

        head_short="$(git rev-parse --short HEAD)"
        printf 'Saved to GitHub. Branch: %s. Latest save: %s.\n' "$branch" "$head_short"
        return 0
    fi

    if (( ahead > 0 )); then
        if ! git push -u "$remote" "HEAD:$branch"; then
            cat >&2 <<'EOF'
mbis save created a local save point, but the upload to GitHub failed.

Your work is still saved on your computer.

GitHub may have changed while this command was running, or GitHub may have
rejected the upload.

A safe next step is:
  mbis save
EOF
            return 1
        fi

        head_short="$(git rev-parse --short HEAD)"
        printf 'Saved to GitHub. Branch: %s. Latest save: %s.\n' "$branch" "$head_short"
        return 0
    fi

    # No upload needed. If tracking was missing, connect it for next time.
    if [[ -z "$tracking" ]]; then
        if git branch --set-upstream-to="$remote_ref" "$branch" >/dev/null 2>&1; then
            printf "Connected this branch to GitHub branch '%s' for next time.\n" "$remote_ref"
        fi
    fi

    if (( made_commit == 1 )); then
        printf 'Your save point is already included after updating from GitHub. Nothing new needed to upload.\n'
    else
        printf 'Nothing to save. Your computer and GitHub already match.\n'
    fi
}

version_line() {
    local label=$1
    shift
    if { "$@" >/tmp/mbis_version_check.txt 2>/dev/null; } 2>/dev/null; then
        printf "%-16s %s\n" "$label" "$(head -n 1 /tmp/mbis_version_check.txt)"
    else
        printf "%-16s %s\n" "$label" "not available"
    fi
}

secret_line() {
    local label=$1
    local env_var=$2

    if [[ -n "$(printenv "$env_var" 2>/dev/null || true)" ]]; then
        printf "%-24s %s\n" "$label" "available"
    else
        printf "%-24s %s\n" "$label" "missing"
    fi
}

cmd_doctor() {
    local root
    root=$(workspace_root)

    echo "MBIS601 doctor"
    echo
    printf "%-16s %s\n" "Workspace" "$root"
    printf "%-16s %s\n" "Codespaces" "${CODESPACES:-false}"
    if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        printf "%-16s %s\n" "Branch" "$(git branch --show-current 2>/dev/null || echo detached)"
        printf "%-16s %s\n" "Remote" "$(git remote get-url origin 2>/dev/null || echo none)"
    else
        printf "%-16s %s\n" "Git repo" "no"
    fi

    echo
    echo "Core tools"
    version_line "git" git --version
    version_line "gh" gh --version
    version_line "python3" python3 --version
    version_line "uv" uv --version
    version_line "node" node --version
    version_line "npm" npm --version
    version_line "php" php --version
    version_line "sqlite3" sqlite3 --version
    version_line "ruff" ruff --version
    version_line "playwright-cli" playwright-cli --version
    version_line "tavily" tvly --version
    version_line "ctx7" ctx7 --version

    echo
    echo "Agent tools"
    version_line "copilot" copilot --version
    version_line "gemini" gemini --version
    version_line "opencode" opencode --version
    version_line "pi" pi --version
    # version_line "kilo" kilo --version
    version_line "codex" codex --version
    version_line "claude code" claude --version
    # version_line "bob" bob --version
    # if has_command vibe && vibe --help >/tmp/mbis_version_check.txt 2>/dev/null; then
    #     printf "%-16s %s\n" "vibe" "available"
    # else
    #     printf "%-16s %s\n" "vibe" "not available"
    # fi

    echo
    echo "Agent state directories"
    for dir in \
        "$HOME/.claude" \
        "$HOME/.codex" \
        "$HOME/.gemini" \
        "$HOME/.vibe" \
        "$HOME/.agents" \
        "$HOME/.copilot" \
        "$HOME/.config/opencode" \
        "$HOME/.config/kilo"
    do
        if [[ -d "$dir" ]]; then
            printf "%-32s %s\n" "$dir" "present"
        else
            printf "%-32s %s\n" "$dir" "missing"
        fi
    done

    echo
    echo "Ports"
    if ss -ltn 2>/dev/null | grep -Eq ":${AGENTSVIEW_PORT}[[:space:]]"; then
        printf "%-16s %s\n" "Port ${AGENTSVIEW_PORT}" "in use"
    else
        printf "%-16s %s\n" "Port ${AGENTSVIEW_PORT}" "free"
    fi
    if ss -ltn 2>/dev/null | grep -Eq ":${NODE_REACT_PORT}[[:space:]]"; then
        printf "%-16s %s\n" "Port ${NODE_REACT_PORT}" "in use"
    else
        printf "%-16s %s\n" "Port ${NODE_REACT_PORT}" "free"
    fi
    if ss -ltn 2>/dev/null | grep -Eq ":${FASTAPI_PORT}[[:space:]]"; then
        printf "%-16s %s\n" "Port ${FASTAPI_PORT}" "in use"
    else
        printf "%-16s %s\n" "Port ${FASTAPI_PORT}" "free"
    fi
    if ss -ltn 2>/dev/null | grep -Eq ":${PYTHON_PORT}[[:space:]]"; then
        printf "%-16s %s\n" "Port ${PYTHON_PORT}" "in use"
    else
        printf "%-16s %s\n" "Port ${PYTHON_PORT}" "free"
    fi
    if ss -ltn 2>/dev/null | grep -Eq ":${WEB_PORT}[[:space:]]"; then
        printf "%-16s %s\n" "Port ${WEB_PORT}" "in use"
    else
        printf "%-16s %s\n" "Port ${WEB_PORT}" "free"
    fi
    if ss -ltn 2>/dev/null | grep -Eq ":${STREAMLIT_PORT}[[:space:]]"; then
        printf "%-16s %s\n" "Port ${STREAMLIT_PORT}" "in use"
    else
        printf "%-16s %s\n" "Port ${STREAMLIT_PORT}" "free"
    fi

    echo
    echo "Authentication"
    if gh auth status -h github.com >/tmp/mbis_gh_auth.txt 2>/dev/null; then
        printf "%-16s %s\n" "GitHub" "authenticated"
    else
        printf "%-16s %s\n" "GitHub" "run \`gh auth login\` if Git or Copilot needs it"
    fi

    echo
    echo "Codespaces secrets / environment"
    secret_line "Anthropic API key" "ANTHROPIC_API_KEY"
    secret_line "Claude OAuth token" "CLAUDE_CODE_OAUTH_TOKEN"
    secret_line "Context7 API key" "CONTEXT7_API_KEY"
    secret_line "Gemini API key" "GEMINI_API_KEY"
    secret_line "Google GenAI key" "GOOGLE_GENERATIVE_AI_API_KEY"
    secret_line "Mistral API key" "MISTRAL_API_KEY"
    secret_line "NVIDIA API key" "NVIDIA_API_KEY"
    secret_line "OpenAI API key" "OPENAI_API_KEY"
    secret_line "OpenCode API key" "OPENCODE_API_KEY"
    secret_line "OpenRouter API key" "OPENROUTER_API_KEY"
    secret_line "Tavily API key" "TAVILY_API_KEY"

}

cmd_stop() {
    local auto_yes=false
    local arg

    for arg in "$@"; do
        case "$arg" in
            --yes)
                auto_yes=true
                ;;
            --help|-h)
                cat <<'EOF'
Usage:
  mbis stop [--yes]

Stops the current GitHub Codespace.

Options:
  --yes    Stop without asking for confirmation.
EOF
                return 0
                ;;
            *)
                die "Unknown option for stop: $arg"
                ;;
        esac
    done

    if [[ "${CODESPACES:-}" != "true" || -z "${CODESPACE_NAME:-}" ]]; then
        die "mbis stop is intended to be run inside a GitHub Codespace."
    fi

    has_command gh || die "GitHub CLI is required for mbis stop."

    echo "mbis stop will stop the current Codespace: ${CODESPACE_NAME}"
    echo "Save your work first with \`mbis save\` or regular Git commands."

    if [[ "$auto_yes" != true ]]; then
        prompt_yes_no "Stop this Codespace now?" || {
            echo "Stop cancelled."
            return 0
        }
    fi

    echo "Stopping Codespace ${CODESPACE_NAME}..."
    gh codespace stop --codespace "$CODESPACE_NAME"
}

cmd_update() {
    local auto_yes=false
    local full_rebuild=false
    local arg

    for arg in "$@"; do
        case "$arg" in
            --yes)
                auto_yes=true
                ;;
            --full)
                full_rebuild=true
                ;;
            --help|-h)
                print_help
                return 0
                ;;
            *)
                die "Unknown option for update: $arg"
                ;;
        esac
    done

    if [[ "${CODESPACES:-}" != "true" || -z "${CODESPACE_NAME:-}" ]]; then
        die "mbis update is intended for GitHub Codespaces. Use the Codespaces rebuild UI when running locally."
    fi
    has_command gh || die "GitHub CLI is required for mbis update."

    echo "mbis update rebuilds the current codespace so devcontainer changes take effect."
    echo "Save your work first with \`mbis save\` or regular Git commands."
    if [[ "$auto_yes" != true ]]; then
        prompt_yes_no "Continue with the rebuild?" || {
            echo "Update cancelled."
            return 0
        }
    fi

    if [[ "$full_rebuild" == true ]]; then
        gh cs rebuild --codespace "$CODESPACE_NAME" --full
    else
        gh cs rebuild --codespace "$CODESPACE_NAME"
    fi
}

cmd_context7() {
    if [[ -z "${CONTEXT7_API_KEY:-}" ]]; then
        cat >&2 <<'EOF'
mbis context7 needs a Context7 API key, but CONTEXT7_API_KEY is not set
in this Codespace.

What to do:
  1. Create a free API key at https://context7.com/dashboard
  2. Add it as a Codespaces secret named CONTEXT7_API_KEY:
       https://github.com/settings/codespaces
       (New secret -> Name: CONTEXT7_API_KEY, Value: your key,
        give this repository access)
  3. Reload this Codespace so the new secret is available.
  4. Run `mbis context7` again.
EOF
        return 1
    fi

    npm install -g ctx7@latest

    ctx7 setup --cli --universal --yes --api-key "$CONTEXT7_API_KEY" || true
    ctx7 setup --cli --claude --yes --api-key "$CONTEXT7_API_KEY" || true
    ctx7 setup --cli --antigravity --yes --api-key "$CONTEXT7_API_KEY" || true
    echo "✓ Context7 CLI setup complete for global, Claude, and Antigravity scopes"

    # Copy ctx7 skills to all agent skill directories
    if [ -d "$HOME/.claude/skills/find-docs" ]; then
        cp -r "$HOME/.claude/skills/find-docs" "$HOME/.agents/skills/"
        cp -r "$HOME/.claude/skills/find-docs" "$HOME/.vibe/skills/"
        echo "✓ Context7 skill copied to ~/.agents/skills/ and ~/.vibe/skills/ for Claude, CoPilot, Gemini-CLI and Mistral Vibe"
    else
        echo "⚠ Warning: Context7 skill not found at .claude/skills/find-docs; skipping global skill copy"
    fi
}

main() {
    local command=${1:-help}
    shift || true

    case "$command" in
        run)
            cmd_run "$@"
            ;;
        sync)
            cmd_sync "$@"
            ;;
        save)
            cmd_save "$@"
            ;;
        home)
            cmd_home "$@"
            ;;
        newproject)
            cmd_newproject "$@"
            ;;
        doctor)
            cmd_doctor "$@"
            ;;
        stop)
            cmd_stop "$@"
            ;;
        update)
            cmd_update "$@"
            ;;
        context7)
            cmd_context7 "$@"
            ;;
        help|--help|-h)
            print_help "$@"
            ;;
        *)
            die "Unknown command: $command"
            ;;
    esac
}

main "$@"
