#!/usr/bin/env bash

set -euo pipefail

AGENTSVIEW_PORT=2223
NODE_REACT_PORT=3000
PYTHON_PORT=5000
FASTAPI_PORT=8000
WEB_PORT=8080
STREAMLIT_PORT=8501

die() {
    echo "Error: $*" >&2
    exit 1
}

has_command() {
    command -v "$1" >/dev/null 2>&1
}

workspace_root() {
    if git rev-parse --show-toplevel >/dev/null 2>&1; then
        git rev-parse --show-toplevel
    else
        pwd
    fi
}

show_preview() {
    local port=$1
    echo "Starting app on http://127.0.0.1:${port}"
    if [[ "${CODESPACES:-}" == "true" ]]; then
        echo "Codespaces should forward port ${port} automatically."
    fi
}

prompt_yes_no() {
    local prompt=$1
    local reply
    read -r -p "${prompt} [y/N] " reply
    [[ "${reply,,}" =~ ^(y|yes)$ ]]
}

append_unique_line() {
    local file=$1
    local line=$2
    if ! grep -Fqx "$line" "$file" 2>/dev/null; then
        printf "%s\n" "$line" >> "$file"
    fi
}

help_style() {
    if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
        H_BOLD=$'\033[1m'
        H_DIM=$'\033[2m'
        H_GREEN=$'\033[32m'
        H_CYAN=$'\033[36m'
        H_RESET=$'\033[0m'
    else
        H_BOLD=""
        H_DIM=""
        H_GREEN=""
        H_CYAN=""
        H_RESET=""
    fi
}

help_title() {
    printf "%b%s%b\n" "$H_BOLD" "$1" "$H_RESET"
}

help_section() {
    printf "\n%b%s%b\n" "$H_BOLD" "$1" "$H_RESET"
}

help_row() {
    local command=$1
    local description=$2
    printf "  %b%-24s%b %s\n" "$H_CYAN" "$command" "$H_RESET" "$description"
}

help_step() {
    local number=$1
    local command=$2
    local description=$3
    printf "  %b%s%b  %b%-26s%b %s\n" \
        "$H_GREEN" "$number" "$H_RESET" "$H_CYAN" "$command" "$H_RESET" "$description"
}

help_footer() {
    [[ "${H_SUPPRESS_FOOTER:-}" == "1" ]] && return 0
    printf "\n%bMore help:%b mbis help terminal | agents | run | git | all\n" "$H_DIM" "$H_RESET"
    printf "%bRead README.md in your workspace home for detailed course guidance.%b\n" "$H_DIM" "$H_RESET"
}

print_help_overview() {
    help_title "MBIS601 Codespace Help"
    printf "%bA quick guide for getting started in this course Codespace.%b\n" "$H_DIM" "$H_RESET"

    help_section "Start here"
    help_step "1" "mbis newproject my-app" "create a project and copy agent templates"
    help_step "2" "pwd" "confirm you are inside your project folder"
    help_step "3" "gemini" "or launch copilot, opencode, codex, claude, pi"

    help_section "MBIS commands"
    help_row "mbis newproject [name]" "create a new project folder"
    help_row "mbis home" "jump back to the workspace home"
    help_row "mbis save" "save and upload your work to GitHub"
    help_row "mbis sync" "pull newer work from GitHub"
    help_row "mbis run [type] [file]" "run a Python, Node, PHP, or web app"
    help_row "mbis doctor" "check your setup"
    help_row "mbis stop" "stop the Codespace when finished"

    help_section "Terminal essentials"
    help_row "pwd" "show where you are"
    help_row "ls" "list files; use ls -la for details"
    help_row "cd [folder]" "move into a folder; cd .. goes up"
    help_row "mkdir [folder]" "create a folder"
    help_row "rm [file]" "remove a file; rm -r [folder] removes a folder"
    help_row "Ctrl+C" "cancel a running command"

    help_section "Stuck?"
    printf "  Copy-paste the command or error into an AI and ask what to do.\n"
    printf "  Claude Haiku 4.5 is available free at https://duck.ai\n"

    help_footer
}

