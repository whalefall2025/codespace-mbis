    help_title "Terminal Basics"
    printf "%bSmall commands you will use often.%b\n" "$H_DIM" "$H_RESET"

    help_section "Navigation"
    help_row "pwd" "print working directory; shows the current path"
    help_row "ls" "list directory contents"
    help_row "ls -la" "show hidden files and detailed information"
    help_row "cd [folder]" "change directory"
    help_row "cd .." "go up one level"
    help_row "mbis home" "return to your workspace home"

    help_section "Files and folders"
    help_row "mkdir [folder]" "create a new directory"
    help_row "rm [file]" "remove a file"
    help_row "rm -r [folder]" "remove a directory"
    help_row "cp [from] [to]" "copy files or directories"
    help_row "mv [from] [to]" "move or rename files and directories"

    help_section "Control"
    help_row "Ctrl+C" "cancel a running command"
    help_row "Up/Down arrows" "move through commands you have run before"

    help_section "Stuck?"
    printf "  Copy-paste an unknown command or error message into an AI.\n"
    printf "  Ask: \"What does this mean, and what should I do?\"\n"
    printf "  Claude Haiku 4.5 is available free at https://duck.ai\n"

    help_footer
}

