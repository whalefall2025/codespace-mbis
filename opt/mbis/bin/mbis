    help_footer
}

print_help_git() {
    help_title "Saving And Syncing Work"
    printf "%bUse these MBIS helpers for the beginner Git workflow.%b\n" "$H_DIM" "$H_RESET"

    help_section "Commands"
    help_row "mbis save" "save your latest work and upload it to GitHub"
    help_row "mbis sync" "pull updates from GitHub to this workspace"

    help_section "When to use them"
    printf "  Run mbis save before taking a break or stopping the Codespace.\n"
    printf "  Run mbis sync when you need newer work from your GitHub repo.\n"
    printf "  If Git reports a conflict, copy-paste the message into an AI\n"
    printf "  and ask what it means before choosing what to keep.\n"

    help_footer
}

print_help_all() {
    H_SUPPRESS_FOOTER=1
    print_help_overview
    printf "\n"
    print_help_terminal
    printf "\n"
    print_help_agents
    printf "\n"
    print_help_run
    printf "\n"
    print_help_git
    H_SUPPRESS_FOOTER=0
    help_footer
}

print_help_topics() {
    printf "Available help topics: terminal, agents, run, git, all\n" >&2
}

print_help() {
    local topic=${1:-overview}
    help_style

    case "$topic" in
        overview)
            print_help_overview
            ;;
        terminal)
            print_help_terminal
            ;;
        agents)
            print_help_agents
            ;;
        run)
            print_help_run
            ;;
        git)
            print_help_git
            ;;
        all)
            print_help_all
            ;;
        *)
            printf "Unknown help topic: %s\n" "$topic" >&2
            print_help_topics
            return 1
            ;;
    esac
}

course_workspace_root() {
    if [[ -n "${CODESPACE_VSCODE_FOLDER:-}" && -d "${CODESPACE_VSCODE_FOLDER}" ]]; then
        echo "${CODESPACE_VSCODE_FOLDER}"
        return 0
    fi
    if [[ -n "${GITHUB_WORKSPACE:-}" && -d "${GITHUB_WORKSPACE}" ]]; then
        echo "${GITHUB_WORKSPACE}"
        return 0
    fi
    if [[ -n "${LOCAL_WORKSPACE_FOLDER:-}" && -d "${LOCAL_WORKSPACE_FOLDER}" ]]; then
        echo "${LOCAL_WORKSPACE_FOLDER}"
        return 0
    fi
    if [[ -n "${RepositoryName:-}" && -d "/workspaces/${RepositoryName}" ]]; then
        echo "/workspaces/${RepositoryName}"
        return 0
    fi

    local root
    root=$(workspace_root)
    if [[ -d "$root/agents-md-templates" ]]; then
        echo "$root"
        return 0
    fi

    die "Could not find the course workspace folder."
}

is_safe_project_name() {
    local name=$1
    [[ "$name" =~ ^[A-Za-z0-9]([A-Za-z0-9-]*[A-Za-z0-9])?$ ]]
}

project_name_has_space() {
    local name=$1
    [[ "$name" =~ [[:space:]] ]]
}

is_exit_reply() {
    case "$1" in
        [Qq]|[Qq][Uu][Ii][Tt]|[Ee][Xx][Ii][Tt])
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

suggest_project_name() {
    local name=$1
    name=$(printf "%s" "$name" | tr '[:space:]' '-' | tr -cs 'A-Za-z0-9-' '-')
    name="${name##-}"
    name="${name%%-}"
    printf "%s" "$name"
}

prompt_for_safe_project_name() {
    local name=$1
    local suggestion reply

    while ! is_safe_project_name "$name"; do
        echo "Project folder names can only use letters, numbers, and hyphens." >&2
        echo "They must start and end with a letter or number." >&2

        if project_name_has_space "$name"; then
            suggestion=$(suggest_project_name "$name")
            if [[ -n "$suggestion" && "$suggestion" != "$name" ]]; then
                echo "Spaces are not allowed in project folder names." >&2
                echo "Suggested name: $suggestion" >&2
                read -r -p "Press Enter to use this name, type a different name, or type 'q' to exit: " reply || return 1
                if [[ -z "$reply" ]]; then
                    name=$suggestion
                elif is_exit_reply "$reply"; then
                    echo "No project created." >&2
                    return 2
                else
                    name=$reply
                fi
                continue
            fi
        fi

        read -r -p "Type a safe project name, or type 'q' to exit: " reply || return 1
        if is_exit_reply "$reply"; then
            echo "No project created." >&2
            return 2
        fi
        name=$reply
    done

    printf "%s\n" "$name"
}

cmd_newproject() {
    if [[ "$#" -eq 0 ]]; then
        cat >&2 <<'EOF'
Usage:
  mbis newproject [name-of-project]

Project names can only use letters, numbers, and hyphens.
EOF
        return 1
    fi

    local raw_name project_name workspace_dir templates_dir project_dir project_path
    local template template_name copied_names=()
    local prompt_status

    raw_name="$*"

    if project_name_has_space "$raw_name" || ! is_safe_project_name "$raw_name"; then
        if project_name=$(prompt_for_safe_project_name "$raw_name"); then
            prompt_status=0
        else
            prompt_status=$?
        fi
        if (( prompt_status == 2 )); then
            return 0
        fi
        if (( prompt_status != 0 )); then
            return "$prompt_status"
        fi
        if [[ -z "$project_name" ]]; then
            return 0
        fi
    else
        project_name=$raw_name
    fi

    workspace_dir=$(course_workspace_root)
    templates_dir="$workspace_dir/agents-md-templates"
    [[ -d "$templates_dir" ]] || die "Could not find agent templates at $templates_dir."

    project_dir="$workspace_dir/$project_name"

    if [[ -e "$project_dir" ]]; then
        echo "A project folder named '$project_name' already exists."
        echo "No files were copied."
        return 0
    fi

    mkdir -p "$project_dir"

    shopt -s nullglob
    for template in "$templates_dir"/*; do
        [[ -f "$template" ]] || continue
        template_name=$(basename "$template")
        [[ "$template_name" == ".DS_Store" || "$template_name" == "README.md" ]] && continue
        cp "$template" "$project_dir/"
        copied_names+=("$template_name")
    done
    shopt -u nullglob

    project_path=$(cd "$project_dir" && pwd -P)

    echo "Created project folder: $project_name"
    if (( ${#copied_names[@]} > 0 )); then
        printf "Copied template files: %s\n" "${copied_names[*]}"
    else
        echo "Copied template files: none found"
    fi
    echo "Project path: $project_path"

    if [[ -n "${MBIS_NEWPROJECT_PATH_FILE:-}" ]]; then
        printf "%s\n" "$project_path" > "$MBIS_NEWPROJECT_PATH_FILE"
    fi
}

cmd_run_python() {
    local target=${1:-}
    export FLASK_RUN_HOST=127.0.0.1
    export FLASK_RUN_PORT=$PYTHON_PORT
    export HOST=127.0.0.1
    export PORT=$PYTHON_PORT
    export UV_CACHE_DIR=${UV_CACHE_DIR:-/tmp/uv-cache}

    if [[ -z "$target" ]]; then
        for candidate in manage.py app.py main.py server.py; do
            if [[ -f "$candidate" ]]; then
                target=$candidate
                break
            fi
        done
    fi

    [[ -n "$target" ]] || die "Could not find a Python entry point. Try \`mbis run python app.py\`."

    show_preview "$PYTHON_PORT"
    if [[ "$target" == "manage.py" ]]; then
        exec uv run python manage.py runserver 127.0.0.1:${PYTHON_PORT}
    fi
    exec uv run python "$target"
}

cmd_run_node() {
    local target=${1:-}
    export HOST=127.0.0.1
    export PORT=$WEB_PORT

    if [[ -z "$target" && -f package.json ]]; then
        if jq -e '.scripts.dev' package.json >/dev/null 2>&1; then
            show_preview "$WEB_PORT"
            echo "Running npm run dev with PORT=${WEB_PORT}."
            exec npm run dev
        fi
        if jq -e '.scripts.start' package.json >/dev/null 2>&1; then
            show_preview "$WEB_PORT"
            echo "Running npm start with PORT=${WEB_PORT}."
            exec npm start
        fi
    fi

    if [[ -z "$target" ]]; then
        for candidate in server.js app.js index.js server.mjs app.mjs index.mjs; do
            if [[ -f "$candidate" ]]; then
                target=$candidate
                break
            fi
        done
    fi

    if [[ -n "$target" ]]; then
        show_preview "$WEB_PORT"
        exec node "$target"
    fi

    if [[ -f index.html ]]; then
        show_preview "$WEB_PORT"
        exec python3 -m http.server "$WEB_PORT" --bind 127.0.0.1
    fi

    die "Could not find a Node entry point. Try \`mbis run node server.js\`."
}

cmd_run_php() {
    local target=${1:-.}
    if [[ -f "$target" ]]; then
        target=$(dirname "$target")
    fi
    show_preview "$WEB_PORT"
    exec php -S 127.0.0.1:${WEB_PORT} -t "$target"
}

cmd_run() {
    local mode=${1:-auto}
    local target=${2:-}

    case "$mode" in
        auto)
            if [[ -f package.json ]]; then
                cmd_run_node "$target"
            elif [[ -f manage.py || -f app.py || -f main.py || -f server.py ]]; then
                cmd_run_python "$target"
            elif [[ -f index.html ]]; then
                cmd_run_node "$target"
            elif [[ -f index.php || -d public ]]; then
                cmd_run_php "${target:-.}"
            else
                die "Could not detect a project type. Try \`mbis run python\`, \`mbis run node\`, or \`mbis run php\`."
            fi
            ;;
        python)
            cmd_run_python "$target"
            ;;
        node)
            cmd_run_node "$target"
            ;;
        php)
            cmd_run_php "$target"
            ;;
        --help|-h)
            print_help run
            ;;
        *)
            die "Unknown runtime: $mode"
            ;;
    esac
}

cmd_sync() {
    git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "mbis sync must be run inside a Git repository."

    local branch
    branch=$(git branch --show-current 2>/dev/null || true)
    [[ -n "$branch" ]] || die "mbis sync needs a normal branch. This repository appears to be detached."

    git remote get-url origin >/dev/null 2>&1 || die "No GitHub remote named origin was found."

    echo "Checking GitHub for newer work..."
    git fetch --prune origin

    local upstream
    upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)
    if [[ -z "$upstream" ]] && git rev-parse --verify --quiet "refs/remotes/origin/${branch}" >/dev/null; then
        git branch --set-upstream-to="origin/${branch}" "$branch" >/dev/null 2>&1 || true
        upstream="origin/${branch}"
    fi

    [[ -n "$upstream" ]] || die "No matching branch was found on GitHub. If this is new work, run \`mbis save\` first."

    echo "Pulling from ${upstream}..."
    if git pull --rebase --autostash; then
        echo "Sync complete."
        return 0
    fi

    echo >&2
    echo "Sync stopped because Git needs your help to resolve a conflict." >&2
    echo "Open the conflicted files, fix the conflict markers, then run:" >&2
    echo "  git add <files>" >&2
    echo "  git rebase --continue" >&2
    echo "To cancel this sync attempt, run:" >&2
    echo "  git rebase --abort" >&2
    return 1
}

cmd_home() {
        cd "$GITHUB_WORKSPACE" || cd /workspaces/$(ls /workspaces | head -1)
}

