    help_title "Running Apps And Preview Ports"
    printf "%bRun apps locally, then open them from the Codespaces Ports tab.%b\n" "$H_DIM" "$H_RESET"

    help_section "Run commands"
    help_row "mbis run" "detect and run a common app entry point"
    help_row "mbis run python app.py" "run a Python app"
    help_row "mbis run node server.js" "run a Node app"
    help_row "mbis run php public" "run a PHP app"

    help_section "Default ports"
    help_row "2223" "AgentsView dashboard"
    help_row "3000" "Node or React apps"
    help_row "5000" "Python Flask apps"
    help_row "8000" "FastAPI apps"
    help_row "8080" "general HTML/CSS/JS web apps"
    help_row "8501" "Streamlit apps"

    help_section "Previewing"
    printf "  Your agent may choose a different port; check its messages.\n"
