    help_section "First-time setup"
    help_step "1" "mbis newproject my-app" "create your project folder"
    help_step "2" "pwd" "check that your prompt is inside that project"
    help_step "3" "gemini" "or run another agent tool below"

    help_section "Tools"
    help_row "copilot" "GitHub Copilot coding agent"
    help_row "gemini" "Google Gemini CLI"
    help_row "opencode" "OpenCode"
    help_row "claude" "Claude Code"
    help_row "codex" "OpenAI Codex"
    help_row "pi" "Pi coding agent"

    help_section "Authentication"
    printf "  Complete sign-in or store API keys before using the tools:\n"
    printf "  https://github.com/settings/codespaces\n"

    help_footer
}

